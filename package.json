{
  "name": "react-base",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite --port 3000",
    "start": "vite --port 3000",
    "build": "vite build && tsc",
    "build:msw": "VITE_APP_ENABLE_MSW=true vite build && tsc",
    "serve": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepare": "husky",
    "check:lint": "eslint src/**/*.{ts,tsx}",
    "check:type": "tsc --noEmit",
    "check:format": "prettier --check .",
    "check": "run-p check:*",
    "check:staged": "lint-staged",
    "fix:lint": "eslint src/**/*.{ts,tsx} --fix",
    "fix:format": "prettier --write .",
    "fix": "run-p fix:*",
    "gen:api": "node scripts/generate-crud.mjs",
    "machine-translate": "inlang machine translate --project project.inlang",
    "postinstall": "yarn i18n:gen",
    "i18n:gen": "paraglide-js compile"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@fontsource/inter": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@t3-oss/env-core": "^0.12.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.2.2",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "antd": "^6.4.3",
    "axios": "^1.12.2",
    "dayjs": "^1.11.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.0.6",
    "zod": "^3.24.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@inlang/cli": "^3.0.0",
    "@inlang/paraglide-js": "2.7.0",
    "@tanstack/eslint-config": "^0.3.0",
    "@tanstack/eslint-plugin-query": "^5.90.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.2.1",
    "msw": "^2.12.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vitest": "^3.0.5",
    "web-vitals": "^4.2.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
